<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">pusher.com</domain>
        <domain includeSubdomains="true">wartil.com</domain>
        <domain includeSubdomains="true">google.com</domain>
        <!-- استثناء لـ Pusher clusters -->
        <domain includeSubdomains="true">ws-eu.pusher.com</domain>
        <domain includeSubdomains="true">ws-mt1.pusher.com</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
